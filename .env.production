# ============================================================================
# Document Analyzer - 배포용 환경 설정
# ============================================================================

# 🔐 데이터베이스 설정
POSTGRES_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql://postgres:your_secure_database_password_here@db:5432/document_analyzer

# 🚀 서버 설정
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=4000

# 🔒 보안 설정 (기본: 안전한 로컬 분석)
ENABLE_EXTERNAL_AI=false
REQUIRE_EXPLICIT_CONSENT=true
ENABLE_DATA_MASKING=true
DEFAULT_AI_MODEL=local

# 🤖 AI API Keys (필요 시 설정)
# 외부 AI 사용 시에만 필요 (ENABLE_EXTERNAL_AI=true)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# 📁 파일 업로드 설정
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=50000000

# 🔍 OCR 설정
TESSERACT_CMD=/usr/bin/tesseract

# 🦙 Ollama (로컬 AI) 설정
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2

# ⚙️ 추가 설정
CORS_ORIGINS=http://localhost,https://yourdomain.com
ALLOWED_HOSTS=localhost,yourdomain.com

# 📊 모니터링 (선택적)
SENTRY_DSN=
ENABLE_METRICS=false

# 🔔 알림 (선택적)
SLACK_WEBHOOK_URL=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
